---
// src/pages/index.astro
import PublicLayout from '@/layouts/PublicLayout.astro';
import Landing from '@/landing/Landing'

const robots = ["index", "follow"];
const title = "Diego Panta | Desarrollador Fullstack & Machine Learning";
const description = "Ingeniero de Sistemas especializado en desarrollo fullstack, machine learning e inteligencia artificial. +1 año transformando ideas en soluciones digitales escalables.";
const keywords = ["Diego Panta", "desarrollador fullstack", "machine learning", "ingeniero de sistemas", "React", "Spring Boot", "Python", "TensorFlow", "Laravel", "portafolio"];
const url = "https://diego-panta.vercel.app";
const imageOG = "/images/profile-og.jpg";
const imagetwt = "/images/profile-og.jpg";
---

<PublicLayout {robots} {title} {description} {keywords} {url} {imageOG} {imagetwt}>
	<Landing client:load />
</PublicLayout>